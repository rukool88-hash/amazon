generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  INVITED
}

enum JobType {
  PRODUCT_IMAGE
  MODEL_SWAP
  DETAIL_PAGE
  SCENE_REPLACE
}

enum JobStatus {
  PENDING
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  TIMEOUT
  ARCHIVED
  ABANDONED
}

enum AssetStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum CreditTransactionType {
  PRE_DEDUCTION
  FORMAL_DEDUCTION
  FAILURE_REFUND
  ADMIN_ADJUSTMENT
  MANUAL_ORDER
}

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  passwordHash   String
  name           String
  avatarUrl      String?
  status         UserStatus @default(ACTIVE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  accounts       Account[]
  sessions       Session[]
  resetTokens    PasswordResetToken[]
  adminAuditLogs AdminAuditLog[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  ip        String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id               String         @id @default(cuid())
  userId           String
  name             String
  slug             String         @unique
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects         Project[]
  generationJobs   GenerationJob[]
  assets           Asset[]
  accountCredits   AccountCredit?
  creditLedgers    CreditLedger[]
  manualOrders     ManualOrder[]
}

model Project {
  id             String          @id @default(cuid())
  accountId      String
  name           String
  description    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  account        Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  generationJobs GenerationJob[]
  assets         Asset[]
}

model GenerationJob {
  id                String        @id @default(cuid())
  accountId         String
  projectId         String?
  templateId        String?
  jobType           JobType
  status            JobStatus     @default(PENDING)
  provider          String?
  providerJobId     String?
  retryCount        Int           @default(0)
  inputPayload      Json
  billingSnapshot   Json
  errorCode         String?
  errorMessage      String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  completedAt       DateTime?
  account           Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  project           Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  outputs           JobOutput[]
  creditLedgers     CreditLedger[]

  @@index([accountId, status, createdAt(sort: Desc)])
  @@index([accountId, jobType, status])
}

model JobOutput {
  id              String        @id @default(cuid())
  generationJobId String
  kind            String
  originUrl       String
  previewUrl      String?
  thumbnailUrl    String?
  metadata        Json?
  createdAt       DateTime      @default(now())
  generationJob   GenerationJob @relation(fields: [generationJobId], references: [id], onDelete: Cascade)
  asset           Asset?
}

model Asset {
  id          String      @id @default(cuid())
  accountId   String
  projectId   String?
  jobOutputId String      @unique
  name        String
  kind        String
  originUrl   String
  previewUrl  String?
  favorite    Boolean     @default(false)
  status      AssetStatus @default(ACTIVE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?
  account     Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  project     Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  jobOutput   JobOutput   @relation(fields: [jobOutputId], references: [id], onDelete: Cascade)
}

model AccountCredit {
  id               String    @id @default(cuid())
  accountId        String    @unique
  availableCredits Int       @default(0)
  reservedCredits  Int       @default(0)
  usedCredits      Int       @default(0)
  updatedAt        DateTime  @updatedAt
  account          Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model CreditLedger {
  id              String                @id @default(cuid())
  accountId       String
  generationJobId String?
  type            CreditTransactionType
  amount          Int
  balanceAfter    Int
  reason          String
  operatorNote    String?
  createdAt       DateTime              @default(now())
  account         Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  generationJob   GenerationJob?        @relation(fields: [generationJobId], references: [id], onDelete: SetNull)
}

model CreditPlan {
  id           String   @id @default(cuid())
  name         String   @unique
  credits      Int
  priceCents   Int
  description  String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ManualOrder {
  id          String   @id @default(cuid())
  accountId   String
  creditPlanId String?
  credits     Int
  operator    String
  note        String?
  createdAt   DateTime @default(now())
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  token      String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PromptTemplate {
  id          String   @id @default(cuid())
  name        String
  jobType     JobType
  version     Int      @default(1)
  provider    String
  prompt      String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminId     String
  action      String
  resource    String
  resourceId  String
  before      Json?
  after       Json?
  createdAt   DateTime @default(now())
  admin       User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
}
